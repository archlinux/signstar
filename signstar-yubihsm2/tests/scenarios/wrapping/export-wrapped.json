      }
    },
    {
      "auth": {
        "user": 5,
        "passphrase_file": "tests/scenarios/keys/auth-key"
      }
    },
    {
      "export_wrapped": {
        "wrap_key_id": 5,
        "object_type": "asymmetric-key",
        "object_id": 5,
